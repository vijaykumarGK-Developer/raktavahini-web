rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if the requester owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ===== Users (Donors) =====
    match /users/{userId} {
      // Anyone can read donor profiles (to search for donors)
      allow read: if true;
      // Create: only authenticated user can create their own profile
      allow create: if isOwner(userId);
      // Update: only the owner can update their profile
      allow update: if isOwner(userId);
      // Delete: only the owner
      allow delete: if isOwner(userId);
    }

    // ===== Hospitals =====
    match /hospitals/{hospitalId} {
      // Anyone can read hospital listings
      allow read: if true;
      // Any authenticated user can register a hospital
      allow create: if isAuth();
      // Only the creator can update/delete (store creator UID)
      allow update: if isAuth() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    // ===== Donation Logs =====
    match /donation_logs/{logId} {
      // Anyone can read logs (for the history page)
      allow read: if true;
      // Authenticated users can create logs
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Only the owner can update/delete
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ===== Emergencies =====
    match /emergencies/{emergencyId} {
      // Anyone can read active emergencies
      allow read: if true;
      // Only authenticated users can broadcast
      allow create: if isAuth() && request.resource.data.requesterId == request.auth.uid;
      // Creator can update (e.g., resolve)
      allow update: if isAuth() && resource.data.requesterId == request.auth.uid;
      allow delete: if isAuth() && resource.data.requesterId == request.auth.uid;
    }
  }
}
